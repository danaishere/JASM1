extends common/layout

block content
  h1 Patterns
  a(href="/patterns/add") Add New Pattern
  
  if error
    p.error #{error}
  
  if patterns && patterns.length > 0
    each pattern in patterns
      .item
        h3 #{pattern.name}
        p #{pattern.description}
        p Difficulty: #{pattern.difficulty}
        p Category: #{pattern.category}
        p Hook Size: #{pattern.hookSize}
        p Price: #{pattern.isFree ? 'FREE' : '$' + pattern.price}
        if pattern.materials && pattern.materials.length > 0
          p Materials: #{pattern.materials.join(', ')}
        form(method="POST" action=`/patterns/delete/${pattern._id}` style="display: inline")
          button(type="submit" onclick="return confirm('Delete this pattern?')") Delete
  else
    p No patterns found.
